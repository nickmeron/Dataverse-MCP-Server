# Dynamics 365 MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to source control.

# ─── Azure AD App Registration (required) ───
D365_TENANT_ID=00000000-0000-0000-0000-000000000000
D365_CLIENT_ID=00000000-0000-0000-0000-000000000000
D365_CLIENT_SECRET=your-client-secret-here

# ─── Environments (optional — you can also add them at runtime via the add_environment tool) ───
#
# Option A: Single URL (auto-selected, simplest setup)
# D365_ORG_URL=https://yourorg.crm.dynamics.com
#
# Option B: Comma-separated URLs (names auto-derived from hostname)
# D365_ENVIRONMENTS=https://yourorg-dev.crm.dynamics.com,https://yourorg.crm.dynamics.com
#
# Option C: JSON array (full control over names)
# D365_ENVIRONMENTS=[{"name":"Dev","url":"https://yourorg-dev.crm.dynamics.com"},{"name":"Prod","url":"https://yourorg.crm.dynamics.com"}]
#
# Option D: No env vars at all — just ask Claude "connect to https://myorg.crm.dynamics.com"
#           and it will call add_environment for you.
#
# CRM regions:
#   .crm.dynamics.com   (Americas)
#   .crm4.dynamics.com  (EMEA)
#   .crm5.dynamics.com  (Asia Pacific)
#   .crm9.dynamics.com  (UK)
#   .crm11.dynamics.com (Japan)

# ─── Optional ───
# D365_API_VERSION=9.2
